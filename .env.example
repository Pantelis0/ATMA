PORT=4000
NODE_ENV=development
ATMA_RUNTIME_ROLE=all
LOG_LEVEL=info
ATMA_ENTITY_NAME=ATMA Labs

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atma
# Optional direct URL for Prisma schema/migrations when using pooled providers like Prisma Postgres:
# DIRECT_DATABASE_URL=postgres://user:password@db.prisma.io:5432/postgres?sslmode=require
REDIS_URL=redis://localhost:6379
# For Supabase:
# - use Direct Connection if your host supports IPv6
# - otherwise use Supavisor session mode
# Direct example:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
# Session pooler example:
# DATABASE_URL=postgres://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# For Upstash with BullMQ/ioredis:
# use the TCP/TLS Redis URL, not the REST URL/token pair
# Example:
# REDIS_URL=rediss://default:<PASSWORD>@<YOUR-DATABASE>.upstash.io:6379
SCHEDULER_ENABLED=true
LOCAL_SCHEDULER_INTERVAL_MS=3600000
SCHEDULER_TIMEZONE=Europe/Athens
SCHEDULE_DAILY_CYCLE_CRON=0 10 * * 1-5
SCHEDULE_REFRESH_RECENT_X_METRICS_CRON=*/30 * * * *
SCHEDULE_GENERATE_PLATFORM_CONTENT_CRON=0 8 * * 1-5
SCHEDULE_RENDER_WEEKLY_VIDEO_CRON=0 18 * * 5
SCHEDULE_PUBLISH_X_SUMMARY_CRON=
SCHEDULE_PUBLISH_DISCORD_SUMMARY_CRON=
MEDIA_OUTPUT_DIR=./generated/media
FFMPEG_PATH=
VIDEO_FONT_PATH=/System/Library/Fonts/Supplemental/Arial.ttf
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_SCENE_DURATION_SEC=4
VIDEO_DEFAULT_MUSIC_PATH=
VIDEO_DEFAULT_VOICEOVER_PATH=
VIDEO_MUSIC_VOLUME=0.18
VIDEO_VOICEOVER_VOLUME=1.0

PAPER_TRADING=true
DEFAULT_SYMBOL=VT
MAX_POSITION_SIZE_PCT=0.1
MAX_DAILY_LOSS_PCT=0.02
MAX_DRAWDOWN_PCT=0.1

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
DISCORD_WEBHOOK_URL=
X_BEARER_TOKEN=
NEXT_PUBLIC_ATMA_API_URL=http://localhost:4000
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=change-me
DASHBOARD_SESSION_SECRET=change-this-secret
DASHBOARD_SESSION_MAX_AGE_SEC=604800
# Preferred stronger auth option:
# DASHBOARD_USERS_JSON=[{"username":"owner","role":"owner","passwordHash":"scrypt:..."}]
